{
  "name": "csss",
  "version": "1.0.0",
  "description": "Cisco Server-sided Scoring System",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "validate-config": "node scripts/validate-config.js",
    "lint": "eslint src public/js testing scripts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm test",
    "test": "node --test --test-force-exit testing/**/*.test.js",
    "test:perf": "node --test testing/integration/pka-performance.test.js",
    "docker:tool": "docker compose exec -u csss csss node tool.js",
    "docker:validate-config": "docker compose exec -u csss csss node scripts/validate-config.js"
  },
  "overrides": {
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "better-sqlite3-session-store": "^0.1.0",
    "chart.js": "^4.5.1",
    "cryptmd5": "^0.1.2",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.17.3",
    "nanoid": "^5.1.6",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "re2": "^1.21.4",
    "socket.io": "^4.8.3",
    "toml": "^3.0.0",
    "xml2js": "^0.6.2"
  }
}
