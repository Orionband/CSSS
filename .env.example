# Optional. Docker Compose reads this file for settings (feature flags, Discord client ID, etc.).
# Secrets stay in secrets/ — do NOT put SESSION_SECRET or DISCORD_CLIENT_SECRET here.

NODE_ENV=production
# Docker: HOST_PORT is the published host port; the container always listens on 10000.
HOST_PORT=10000
APP_TITLE=CSSS ENGINE

RETAIN_PKA=false
RETAIN_XML=false
SHOW_LEADERBOARD=false
SHOW_HISTORY=false
ALLOW_REGISTRATION=false

DEFAULT_MAX_UPLOAD_MB=50
MAX_WORKERS=4
MAX_QUEUE_DEPTH=50
SHUTDOWN_DRAIN_TIMEOUT_MS=130000
SERVER_CLOSE_TIMEOUT_MS=3000
STOP_GRACE_PERIOD=150s

DISCORD_AUTH_ENABLED=false
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=
# DISCORD_OAUTH_SCOPE=identify

# Uncomment when running behind a reverse proxy or cloud load balancer:
# TRUST_PROXY=loopback
# TRUST_PROXY=1

# Skip missing PKA file checks during local dev (optional):
# CSSS_SKIP_ASSET_VALIDATION=true
